@using static FilterBuilder.Components.ConditionExtensions

<span class="fb-value-wrapper">
    @if (Kind == FactValueKind.Bool)
    {
        <PillDropdown TValue="bool"
                      Value="@BoolVal"
                      Items="@_boolOptions"
                      Display="@(b => b ? "true" : "false")"
                      CssClass="fb-pill--value"
                      ValueChanged="@OnBoolChanged" />
    }
    else if (Kind == FactValueKind.Number)
    {
        <input class="fb-value-input"
               type="number"
               value="@NumberVal"
               placeholder="Enter a value"
               @onchange="OnNumberChanged" />
    }
    else
    {
        <input class="fb-value-input"
               type="text"
               value="@TextVal"
               placeholder="Enter a value"
               @onchange="OnTextChanged" />
    }
</span>

@code {
    [Parameter, EditorRequired] public FactValueKind Kind { get; set; }
    [Parameter, EditorRequired] public FactValue? Value { get; set; }
    [Parameter, EditorRequired] public EventCallback<FactValue> ValueChanged { get; set; }

    private static readonly IReadOnlyList<bool> _boolOptions = new[] { true, false };

    private string TextVal => Value is FactValue.Text t ? t.Value : "";
    private decimal NumberVal => Value is FactValue.Number n ? n.Value : 0;
    private bool BoolVal => Value is FactValue.Bool b ? b.Value : false;

    private Task OnTextChanged(ChangeEventArgs e) =>
        ValueChanged.InvokeAsync(new FactValue.Text(e.Value?.ToString() ?? ""));

    private Task OnNumberChanged(ChangeEventArgs e) =>
        decimal.TryParse(e.Value?.ToString(), out var d)
            ? ValueChanged.InvokeAsync(new FactValue.Number(d))
            : Task.CompletedTask;

    private Task OnBoolChanged(bool b) =>
        ValueChanged.InvokeAsync(new FactValue.Bool(b));
}
