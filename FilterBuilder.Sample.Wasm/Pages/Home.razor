@page "/"

<PageTitle>FilterBuilder Demo</PageTitle>

<h1>FilterBuilder Demo</h1>
<p>An interactive condition builder with no external UI dependencies.</p>

<ConditionEditor Condition="@_condition"
                 Fields="@_fields"
                 ConditionChanged="@(c => _condition = c)" />

<div style="margin-top: 2rem;">
    <h2>Condition tree</h2>
    <pre style="font-size:12px; background:#f6f8fa; padding:16px; border-radius:6px; overflow:auto; border:1px solid #e2e8f0">@Dump(_condition)</pre>
</div>

@code {
    private static readonly IReadOnlyList<FieldDef> _fields =
    [
        new FieldDef("Name",     "Name",      FactValueKind.Text),
        new FieldDef("Category", "Category",  FactValueKind.Text),
        new FieldDef("Price",    "Price",     FactValueKind.Number),
        new FieldDef("InStock",  "In Stock",  FactValueKind.Bool),
    ];

    private Condition _condition = new Condition.All(
    [
        new Condition.Atom("Name",  Operator.Contains, new FactValue.Text("widget")),
        new Condition.Atom("Price", Operator.Lte,      new FactValue.Number(100)),
    ]);

    private static string Dump(Condition c, int indent = 0)
    {
        var pad = new string(' ', indent * 2);
        return c switch
        {
            Condition.Atom a  => $"{pad}Atom({a.Field} {a.Op} {a.Value})",
            Condition.All all => $"{pad}All[\n{string.Join("\n", all.Children.Select(x => Dump(x, indent + 1)))}\n{pad}]",
            Condition.Any any => $"{pad}Any[\n{string.Join("\n", any.Children.Select(x => Dump(x, indent + 1)))}\n{pad}]",
            Condition.Not not => $"{pad}Not(\n{Dump(not.Inner, indent + 1)}\n{pad})",
            _                 => $"{pad}{c}",
        };
    }
}
