@page "/"

<PageTitle>FilterBuilder Demo</PageTitle>

<h1>FilterBuilder Demo</h1>
<p>An interactive condition builder with no external UI dependencies.</p>

<ConditionEditor Condition="@_condition"
                 Fields="@_fields"
                 ConditionChanged="@(c => _condition = c)" />

<div style="margin-top: 2rem;">
    <h2>Condition tree</h2>
    <pre style="font-size:12px; background:#f6f8fa; padding:16px; border-radius:6px; overflow:auto; border:1px solid #e2e8f0">@Dump(_condition)</pre>
</div>

@code {
    private static readonly IReadOnlyList<FieldDef> _fields =
    [
        new FieldDef("chartName", "Chart Name", FactValueKind.Text),
        new FieldDef("amount",    "Amount",     FactValueKind.Number),
        new FieldDef("date",      "Date",       FactValueKind.Text),
        new FieldDef("category",  "Category",   FactValueKind.Text),
        new FieldDef("inStock",   "In Stock",   FactValueKind.Bool),
    ];

    // Seed condition: an AND group with a label (collapsed by default in the UI)
    // plus a sibling unlabelled condition, to demonstrate the feature.
    private Condition _condition = new Condition.All(
    [
        new Condition.All(
            [
                new Condition.Atom("chartName", Operator.Eq,  new FactValue.Text("MAIN")),
                new Condition.Atom("amount",    Operator.Gte, new FactValue.Number(1000)),
                new Condition.Atom("amount",    Operator.Lte, new FactValue.Number(50000)),
                new Condition.Atom("date",      Operator.Gte, new FactValue.Text("2026-01-01")),
                new Condition.Atom("date",      Operator.Lte, new FactValue.Text("2026-04-01")),
            ]
        ) { Label = "normal medium-value Q1 spend" },
        new Condition.Atom("category", Operator.Neq, new FactValue.Text("internal")),
    ]);

    private static string Dump(Condition c, int indent = 0)
    {
        var pad = new string(' ', indent * 2);
        var labelTag = string.IsNullOrEmpty(c.Label) ? "" : $" [{c.Label}]";
        return c switch
        {
            Condition.Atom a  => $"{pad}Atom({a.Field} {a.Op} {a.Value}){labelTag}",
            Condition.All all => $"{pad}All{labelTag}[\n{string.Join("\n", all.Children.Select(x => Dump(x, indent + 1)))}\n{pad}]",
            Condition.Any any => $"{pad}Any{labelTag}[\n{string.Join("\n", any.Children.Select(x => Dump(x, indent + 1)))}\n{pad}]",
            Condition.Not not => $"{pad}Not{labelTag}(\n{Dump(not.Inner, indent + 1)}\n{pad})",
            _                 => $"{pad}{c}",
        };
    }
}
